#! /usr/bin/env loki


loki-set-log-prefix "TZ: "

loki-log info "Validating task0"

if ! [ -x "run.sh" ]; then
    loki-log err "File 'run.sh' does not exist or is not executable"
    exit 5
fi

lokiw -e -u "./run.sh | shasum -a 256 | cut -f1 -d' '"

loki-get-out

pwd

loki-assert-eq "83b99602b788c611a39357a6d19e82eb5cd977637185d8c71da7dc42f178a123" "$(loki-get-out)"

loki-points +50
