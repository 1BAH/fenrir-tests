#! /usr/bin/env loki

loki-set-log-prefix "SM: "

function commit-hash {
    git show -s --format="%h" "$1"
}


loki-log info "Validating commits tree.."

if ! fenrir-change-branch "submodules"; then
    loki-log err "Terminating.."
    exit 1
fi

loki-prog "Inspecting module 'koshchei'.."

koshej_repo=$(cat .gitmodules | grep -A 1 koshchei | grep url | cut -f2 -d'=')
koshej_namespace=$(dirname "$koshej_repo")
koshej_project=$(basename "$koshej_repo" '.git')

koshej_meta=$(curl --url "https://gitlab.com/api/v4/projects/${koshej_namespace}%2F${koshej_project}" &> /dev/null)

lokiw -e -u "echo '$koshej_meta' | grep -q forked_from_project"
lokiw -e -u "echo '$koshej_meta' | grep -oE '\"namespace\":{[^{}]*}' | head -n 1 | grep -q '\"kind\":\"user\"'"
lokiw -e -u "echo '$koshej_meta' | grep -q '\"name\":\"koshej\"'"

loki-gorp

loki-points +10
