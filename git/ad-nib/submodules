#! /usr/bin/env loki

loki-set-log-prefix "SM: "

if ! fenrir-change-branch "submodules"; then
    loki-log err "Terminating.."
    exit 1
fi

loki-prog "Inspecting module 'koshchei'.."

koshej_repo=$(cat .gitmodules | grep -A 1 koshchei | grep url | cut -f2 -d'=')
koshej_namespace=$(basename "$(dirname "$koshej_repo")")
koshej_project=$(basename "$koshej_repo" '.git')

koshej_meta=$(curl --url "https://gitlab.com/api/v4/projects/${koshej_namespace}%2F${koshej_project}" 2> /dev/null)

lokiw -e -u "echo '$koshej_meta' | grep -q forked_from_project"
lokiw -e -u "echo '$koshej_meta' | grep -oE '\"namespace\":\\{[^{}]*\\}' | head -n 1 | grep -q '\"kind\":\"user\"'"
lokiw -e -u "echo '$koshej_meta' | grep -q '\"name\":\"koshej\"'"

loki-gorp

loki-prog "Setting up the repository.."

if ! [ -x "setup.sh" ]; then
    loki-log fail "Cannot find 'setup.sh'"
    exit 3
fi

lokiw -e ./setup.sh

loki-gorp

loki-prog "Killing Koshchei.."

if ! [ -x "oak/hare/duck/egg.sh" ]; then
    loki-log fail "Cannot find the egg!"
    exit 3
fi

lokiw -e ./oak/hare/duck/egg.sh

loki-assert-eq "Er ist tot!" "$(loki-get-out)"
loki-assert-eq "%" "%$(loki-get-err)"

loki-gorp

loki-points +20
