#! /usr/bin/env loki

loki-set-log-prefix "RB: "

function get-info {
    git show -s --format="$1" "$2"
}

if ! fenrir-change-branch "rebase"; then
    loki-log err "Terminating.."
    exit 1
fi

merge_commit=$(git log --merges --format="%h" rebase)

if [ -n "$merge_commit" ]; then
    loki-log err "You have a merge commit"
    exit 1
fi

loki-prog "Validating messages & bodies"

loki-assert-eq "venezia" "$(get-info "%s" rebase~0)"
loki-assert-eq "%" "%$(get-info "%b" rebase~0)"
loki-assert-eq "milano"  "$(get-info "%s" rebase~1)"
loki-assert-eq "%" "%$(get-info "%b" rebase~1)"
loki-assert-eq "torino"  "$(get-info "%s" rebase~2)"
loki-assert-eq "firenze & bologna" "$(get-info "%b" rebase~2)"
loki-assert-eq "roma"    "$(get-info "%s" rebase~3)"
loki-assert-eq "%" "%$(get-info "%b" rebase~3)"
loki-assert-eq "napoli"  "$(get-info "%s" rebase~4)"
loki-assert-eq "%" "%$(get-info "%b" rebase~4)"

loki-gorp

loki-prog "Validating root commit"
loki-assert-regeq "^$(get-info "%h" rebase~5)*$" "918367f"
loki-gorp

loki-prog "Validating file contents"

loki-assert-eq "$(cat <<- CORRECT
#! /usr/bin/env nash

echo HI
CORRECT
)" "$(git show rebase~4:script.sh)"

loki-assert-eq "$(cat <<- CORRECT
#! /usr/bin/env bash

echo HI
CORRECT
)" "$(git show rebase~3:script.sh)"

loki-assert-eq "$(cat <<- CORRECT
#! /usr/bin/env bash

echo 'Pizza & Pasta'
CORRECT
)" "$(git show rebase~2:script.sh)"

loki-assert-eq "$(cat <<- CORRECT
#! /usr/bin/env bash

echo 'Pizza & Pasta & Vino'
CORRECT
)" "$(git show rebase~1:script.sh)"

loki-assert-eq "$(cat <<- CORRECT
#! /usr/bin/env bash

echo 'Tartufo'
CORRECT
)" "$(git show rebase~0:script.sh)"

loki-gorp

loki-prog "Validating file mode"

loki-assert-eq "100755" "$(git ls-tree rebase~0 script.sh | cut -f1 -d' ')"
loki-assert-eq "100755" "$(git ls-tree rebase~1 script.sh | cut -f1 -d' ')"
loki-assert-eq "100755" "$(git ls-tree rebase~2 script.sh | cut -f1 -d' ')"
loki-assert-eq "100755" "$(git ls-tree rebase~3 script.sh | cut -f1 -d' ')"
loki-assert-eq "100644" "$(git ls-tree rebase~4 script.sh | cut -f1 -d' ')"

loki-gorp

loki-points +10
