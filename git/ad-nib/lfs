#! /usr/bin/env loki

loki-set-log-prefix "LFS: "

if ! fenrir-change-branch "lfs"; then
    loki-log err "Terminating.."
    exit 1
fi

if ! [ -f logo.png ]; then
    loki-log err "File 'logo.png' was not found"
    exit 2
fi

loki-assert-eq "927e0cea650aa65e30adeea0974099f1c3e676059c87700babadd789830a8fa4" \
               "$(cat logo.png | shasum -a 256 | cut -f1 -d' ')" \
               "File 'logo.png' is corrupted!"

loki-assert-eq 1 "$(git lfs ls-files | wc -l | tr -d "$IFS")"
lokiw -e -u "git lfs locks | grep -q logo.png"

loki-points +10
