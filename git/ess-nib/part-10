#! /usr/bin/env loki

loki-set-log-prefix "P10: "

loki-log info "Validating commits tree.."

if ! fenrir-change-branch "16"; then
    loki-log err "Terminating.."
    exit 1
fi

loki-log info "Validating file mode.."

meta=(`git ls-files -s "moduleB/deps"`)
if [ "${meta[0]}" != '120000' ]; then
    loki-log err "Invalid file mode"
    exit 1
fi

loki-log info "Verifying link.."

lokiw -e readlink moduleB/deps


loki-assert-eq "../moduleA/deps" "$(loki-get-out)"

loki-points +10
