#! /usr/bin/env loki

loki-set-log-prefix "P8: "

function commit-hash {
    git show -s --format="%h" "$1"
}

function commit-name {
    git show -s --format="%s" "$1"
}


loki-log info "Validating commits tree.."

if ! fenrir-change-branch "13" || \
   ! fenrir-change-branch "14"; then
        loki-log err "Terminating.."
        exit 1
fi

loki-assert-regeq "^$(commit-hash "14~1")*$" "da5b652" "You have modified more than 1 commit"
loki-assert-regeq "^$(commit-hash "13~0")*$" "87d598b" "You have modified branch '13'"

loki-assert-eq '133' "$(commit-name "14")" "Invalid message"

loki-log info "Validating file content.."

lokiw -e git blame 13.p
content=$(loki-get-out)

loki-assert-eq 5 "$(echo "$content" | wc -l)"

loki-assert-regeq "^$(echo "$content" | sed '1p;d' | cut -f1 -d' ')*$" "467dd8ea"
loki-assert-regeq "^$(echo "$content" | sed '2p;d' | cut -f1 -d' ')*$" "da5b6520"
loki-assert-regeq "^$(echo "$content" | sed '4p;d' | cut -f1 -d' ')*$" "97c72f91"
loki-assert-regeq "^$(echo "$content" | sed '5p;d' | cut -f1 -d' ')*$" "5b42ea2e"

loki-assert-eq "$(echo "$content" | sed '1p;d' | cut -f7 -d' ')" "5"
loki-assert-eq "$(echo "$content" | sed '2p;d' | cut -f7 -d' ')" "4"
loki-assert-eq "$(echo "$content" | sed '3p;d' | cut -f7 -d' ')" "3"
loki-assert-eq "$(echo "$content" | sed '4p;d' | cut -f7 -d' ')" "2"
loki-assert-eq "$(echo "$content" | sed '5p;d' | cut -f7 -d' ')" "1"

loki-points +10
