#! /usr/bin/env loki

loki-set-log-prefix "P7: "

function get-info {
    git show -s --format="$1" "$2"
}

loki-log info "Validating commits tree.."

if ! fenrir-change-branch "12"; then
    loki-log err "Terminating.."
    exit 1
fi


loki-log info "Validating last commit"

loki-assert-regeq "^$(get-info '%h' "12~1")*$" "ec4c960" "You have modified more than 1 commit"

loki-assert-eq '12: fixed' "$(get-info '%s' "12")" "Invalid message"
loki-assert-eq 'Snusmumriken' "$(get-info '%an' "12")" "Invalid author"
loki-assert-eq 'snus@mumij.troll' "$(get-info '%ae' "12")" "Invalid author"
loki-assert-eq '2012-12-12T12:12:12+01:00' "$(get-info '%aI' "12")" "Invalid date"

lokiw -e ./script.bash
loki-assert-eq '0_0' "$(loki-get-out)" "Invalid file"

loki-points +10
