#! /usr/bin/env loki

loki-set-log-prefix "P5: "

function commit-name {
    git show -s --format="%s" "$1"
}


loki-log info "Validating commits tree.."

if ! fenrir-change-branch "10"; then
    loki-log err "Terminating.."
    exit 1
fi

if [ "$(commit-name "10~0")" != 'Revert "11"' ] ; then
    loki-log err "Wrong commit message"
    exit 1
fi

loki-log info "Validating files content.."

lokiw -e git blame 10.q
content=$(loki-get-out)

loki-assert-eq 3 "$(echo "$content" | wc -w)"

loki-assert-regeq "^$(echo "$content" | sed '1p;d' | cut -f1 -d' ')*$" "040c6b3b"
loki-assert-regeq "^$(echo "$content" | sed '2p;d' | cut -f1 -d' ')*$" "b64dc139"
loki-assert-regeq "^$(echo "$content" | sed '3p;d' | cut -f1 -d' ')*$" "fd55e56e"

loki-assert-eq "$(echo "$content" | sed '1p;d' | cut -f7 -d' ')" "A"
loki-assert-eq "$(echo "$content" | sed '2p;d' | cut -f7 -d' ')" "C"
loki-assert-eq "$(echo "$content" | sed '3p;d' | cut -f7 -d' ')" "D"

loki-points +10
