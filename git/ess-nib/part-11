#! /usr/bin/env loki

loki-set-log-prefix "P11: "

loki-log info "Validating commits tree.."

if ! fenrir-change-branch "17"; then
    loki-log err "Terminating.."
    exit 1
fi

loki-log info "Searching script.."

if ! [ -x "install" ]; then
    loki-log err "'install' was not found"
    exit 1
fi

loki-log succ "'install' was found"


loki-log info "Saving '.git/hooks'.."

backup=$(fenrir-tmp -d)

cp -r .git/hooks/ "$backup"

function backup_terminate {
    msg=$1

    loki-log fail "$msg"

    rm -r .git/hooks
    mv "$backup/hooks" .git/

    if git status | grep -q bugaga; then
        git restore --staged bugaga
    fi

    if [ -f bugaga ]; then
        rm bugaga
    fi

    exit 1
}


loki-log info "Installing hooks.."

lokiw -e ./install

loki-log succ "Installed"

loki-log info "Creating file 'bugaga'.."
touch bugaga

loki-log info "Running 'git add bugaga'.."
git add bugaga

loki-log info "Running 'git commit -m \"BAD MESSAGE\"'.."
if lokiw git commit -m "BAD MESSAGE"; then
    backup_terminate "File has been commited!"
fi
loki-log succ "Hook works correct"

loki-log info "Running 'git commit -m \"[FIX] BAD\"'.."
if lokiw git commit -m "[FIX] BAD"; then
    backup_terminate "File has been commited!"
fi
loki-log succ "Hook works correct"

loki-log info "Running 'git commit -m \"[ АDD ] Tricky\"'.."
if lokiw git commit -m "[ АDD ] Tricky"; then
    backup_terminate "File has been commited! ('A' is cyrillic)"
fi
loki-log succ "Hook works correct"

loki-log info "Running 'git commit -m \"[ ADD ]Tricky\"'.."
if lokiw git commit -m "[ ADD ]Tricky"; then
    backup_terminate "File has been commited!"
fi
loki-log succ "Hook works correct"

loki-log info "Running 'git commit -m \" [ ADD ] Tricky\"'.."
if lokiw git commit -m " [ ADD ] Tricky"; then
    backup_terminate "File has been commited!"
fi
loki-log succ "Hook works correct"

loki-log info "Running 'git commit -m \"[ ADD ] Triсky\"'.."
if lokiw git commit -m "[ ADD ] Triсky"; then
    backup_terminate "File has been commited! ('с' is cyrillic)"
fi
loki-log succ "Hook works correct"

loki-log info "Running 'git commit -m \"[ ADD ] Good\"'.."
if ! lokiw git commit -m "[ ADD ] Good"; then
    backup_terminate "File has not been commited!"
fi
loki-log succ "Hook works correct"

git reset --soft HEAD~1

loki-log info "Running 'git commit -m \"[ FIX ] Go0od\"'.."
if ! lokiw git commit -m "[ FIX ] Good"; then
    backup_terminate "File has not been commited!"
fi
loki-log succ "Hook works correct"

git reset --soft HEAD~1

loki-log info "Running 'git commit -m \"[ DEL ] 1G1o1O1d1\"'.."
if ! lokiw git commit -m "[ DEL ] 1G1o1O1d1"; then
    backup_terminate "File has not been commited!"
fi
loki-log succ "Hook works correct"

git reset --hard HEAD~1

rm -r .git/hooks
mv "$backup/hooks" .git/

loki-points +30
