#! /usr/bin/env loki

loki-set-log-prefix "SSH-2: "

image="registry.gitlab.com/atpd/progtech/tech-tasks/ssh/ssh:latest"

function verify_script {
    local filename=$1
    if ! [ -x "$filename" ]; then
        loki-log err "File '$filename' does not exist or is not executable!"
        exit 8
    fi
}

lokiw -e pushd part-2

verify_script "setup.sh"
verify_script "part-2.sh"

function test_file {
    local filename=$1

    if ! [ -f "$filename" ]; then
        loki-log err "Cannot find '$filename'"
        finalise 8
    fi
    loki-assert-eq "${msg}" "$(< "$filename")"
}

#################################################################################################
loki-log info "Starting test environment.."

function finalise {
    docker stop "client" "server" &> /dev/null
    docker network rm "$net" &> /dev/null
    loki-log fail "Script exited with non-zero code: <$1>"
    exit "$1"
}

loki-assert-cb "docker stop client server &> /dev/null && docker network rm $net &> /dev/null"

voldir=$(fenrir-tmp -d)

net="${RANDOM}-${RANDOM}-${RANDOM}-${RANDOM}-${RANDOM}-${RANDOM}-${RANDOM}"
lokiw -e docker network create "$net"

for id in client server; do
    # shellcheck disable=SC2046
    cont=$(docker run --rm -d \
        -e "LOKI_VERBOSE" \
        --net "$net" \
        --name "$id" \
        "$image")
    # shellcheck disable=SC2181
    if (( $? != 0 )); then
        loki-log err "Cannot start server"
        exit 66
    fi
done

# SERVER

msg="Velociraptor $RANDOM"

cat <<- SCRIPT > "$voldir/email.addr"
${msg}
SCRIPT

lokiw docker cp "$voldir" server:/home/fikus/from || {
    finalise $?
}

lokiw docker exec server chown -R fikus /home/fikus || {
    finalise $?
}

# CLIENT

mkdir -p "$voldir/otter/beaver"

cat <<- SCRIPT > "$voldir/otter/email.addr"
${msg}
SCRIPT

cat <<- SCRIPT > "$voldir/otter/beaver/email.addr"
${msg}
SCRIPT

lokiw docker exec client mkdir -p /home/fikus/from || {
    finalise $?
}

lokiw docker cp "$voldir" 'client:/home/fikus/from/emails.d' || {
    finalise $?
}

lokiw docker exec client chown -R fikus /home/fikus || {
    finalise $?
}

loki-log info "Server and client have started"

#######################################################################################

loki-prog "Setting up SSH connection.."

lokiw docker cp --follow-link "setup.sh" client:/home/fikus/ || {
    finalise $?
}

lokiw docker exec client chown -R fikus /home/fikus || {
    finalise $?
}

loki-log info "Running setup.sh.."

lokiw docker exec -u fikus client ./setup.sh || {
    finalise $?
}

loki-log info "Testing the connection.."

lokiw docker exec -u fikus client ssh fikus@server "echo Hello World!" || {
    finalise $?
}

loki-assert-out "Hello World!"

loki-gorp

#########################################################################################

loki-prog "Verifying the main script.."

lokiw docker cp "part-2.sh" client:/home/fikus/ || {
    finalise $?
}

lokiw docker exec client chown -R fikus /home/fikus || {
    finalise $?
}

loki-log info "Running part-2.sh.."


lokiw docker exec -u fikus client ./part-2.sh || {
    finalise $?
}


loki-prog "Testing client.."
rm -fr "${voldir:?"It cannot be empty"}/"*

lokiw docker cp client:/home/fikus/to "$voldir" || {
    finalise $?
}

loki-assert-eq 1 "$(find "$voldir" -type f | wc -l | tr -d "$IFS")"

test_file "$voldir/to/addr.email"

loki-gorp

loki-prog "Testing server.."
rm -fr "${voldir:?"It cannot be empty"}/"*

lokiw docker cp server:/home/fikus/to "$voldir" || {
    finalise $?
}

loki-assert-eq 3 "$(find "$voldir" -type f | wc -l | tr -d "$IFS")"

test_file "$voldir/to/addrs/email.addr"
test_file "$voldir/to/addrs/otter/email.addr"
test_file "$voldir/to/addrs/otter/beaver/email.addr"

loki-gorp

loki-gorp

loki-points +30

docker stop server client &> /dev/null
docker network rm "$net" &> /dev/null
