#! /usr/bin/env loki

lokiw pushd part-1 || {
    loki-log fail "Cannot switch to 'part-1' directory"
    exit 7
}

loki-set-log-prefix "FTP-1: "

image="garethflowers/ftp-server"
filename="part-1.sh"

if ! [ -x "$filename" ]; then
    loki-log err "File '$filename' does not exist or is not executable!"
    exit 8
fi

#################################################################################################

function finalise {
    docker stop "client" "server" &> /dev/null
    docker network rm "$net" &> /dev/null
    loki-log fail "Script exited with non-zero code: <$1>"
    exit "$1"
}

loki-assert-cb "docker stop client server &> /dev/null && docker network rm $net &> /dev/null"

# Credentials
export USER="tom"
export PASSWORD="lizard"

net="${RANDOM}-${RANDOM}-${RANDOM}-${RANDOM}-${RANDOM}-${RANDOM}-${RANDOM}"
lokiw -e docker network create "$net"

# Client
cont=$(docker run --rm -d \
    -e "LOKI_VERBOSE" -e "USER" -e "PASSWORD" \
    --net "$net" \
    --name "client" \
    "registry.gitlab.com/atpd/progtech/tech-tasks/ftp:latest")
# shellcheck disable=SC2181
if (( $? != 0 )); then
    loki-log err "Cannot start client"
    exit 66
fi

# FTP server
cont=$(docker run --rm -d \
    --name server --net "$net" \
    -e "PUBLIC_IP=192.168.0.1" -e "FTP_PASS=$PASSWORD" -e "FTP_USER=$USER" \
    -p "20-21:20-21/tcp" -p "40000-40009:40000-40009/tcp" \
    "$image")
# shellcheck disable=SC2181
if (( $? != 0 )); then
    loki-log err "Cannot start server"
    exit 66
fi


voldir=$(fenrir-tmp -d)
mkdir -p "$voldir/kotlin"

value="Running from script: $RANDOM"
echo "echo '$value'" > "$voldir/kotlin/groovy.sh"

lokiw docker exec server mkdir -p "/home/$USER" || {
    finalise $?
}
lokiw docker cp "$voldir" "server:/home/$USER/java" || {
    finalise $?
}

sleep 1s
loki-log info "Server is running on 'server'"

loki-prog "Verifying the main script.."

lokiw docker cp "part-1.sh" client:/home/fikus/ || {
    finalise $?
}

lokiw docker exec -u root client chown -R fikus /home/fikus || {
    finalise $?
}

loki-log info "Running part-1.sh.."

lokiw docker exec -u fikus client ./part-1.sh || {
    finalise $?
}

loki-assert-out "$value"

loki-points +50

docker stop "client" "server" &> /dev/null
docker network rm "$net" &> /dev/null
