#! /usr/bin/env loki

loki-set-log-prefix "DSd: "

if ! [ -d zhira-package ]; then
    loki-log err "Cannot find directory <zhira-package>"
    exit 5
fi

image="registry.gitlab.com/atpd/progtech/tech-tasks/dpkg-systemd/dpkg-systemd:latest"


function run_server {
    lokiw docker exec -u root server "$@"
}

##########################
loki-log info "Starting test environment.."

function finalise {
    docker stop "client" "server" &> /dev/null
    docker network rm "$net" &> /dev/null
    loki-log fail "Script exited with non-zero code: <$1>"
    exit "$1"
}

loki-assert-cb "docker stop client server &> /dev/null && docker network rm $net &> /dev/null"

net="${RANDOM}-${RANDOM}-${RANDOM}-${RANDOM}-${RANDOM}-${RANDOM}-${RANDOM}"
lokiw -e docker network create "$net"

for id in client server; do
    # shellcheck disable=SC2034
    cont=$(docker run --rm -d \
        -e "LOKI_VERBOSE" \
        --net "$net" \
        --name "$id" \
        "$image")
    # shellcheck disable=SC2181
    if (( $? != 0 )); then
        loki-log err "Cannot start server"
        exit 66
    fi
done

lokiw docker cp . server:/home/fikus/ || finalise $?

loki-log info "The environment is ready"

loki-log info "Installing package.."

run_server make || finalise $?
run_server dpkg -b zhira-package || finalise $?
run_server apt install ./zhira-package.deb || finalise $?

loki-log info "The package is installed"

loki-prog "Tests (running).."
run_server curl server:23456 || finalise $?
loki-assert-out "Got: <78> bytes"
run_server curl server:23456 -d qwerty || finalise $?
loki-assert-out "Got: <153> bytes"
loki-gorp
loki-prog "Tests (stopped).."
run_server systemctl stop zhira
run_server curl server:23456 -d qwerty && finalise $?
loki-gorp
loki-prog "Tests (restarted).."
run_server systemctl start zhira
run_server curl server:23456 || finalise $?
loki-assert-out "Got: <78> bytes"
run_server curl server:23456 -d qwerty || finalise $?
loki-assert-out "Got: <153> bytes"
loki-gorp
loki-prog "Tests (copyrights).."
run_server ls /usr/share/doc/zhira/copyright || finalise $?
loki-gorp
loki-prog "Tests (uninstall).."
run_server apt purge zhira || finalise $?
run_server curl server:23456 -d qwerty && finalise $?
run_server ls /etc/systemd/system/zhira.service && finalise $?
loki-gorp

loki-points +25
