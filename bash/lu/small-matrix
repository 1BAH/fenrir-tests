#! /usr/bin/env loki


destination=$(fenrir-read-conf main root)

loki-log info "SM: Running on small matrix (3x3).."

# Setup logs
src="$(fenrir-task-path cfgs)/in_small.csv"
l="$(fenrir-task-path cfgs)/l_small.csv"
u="$(fenrir-task-path cfgs)/u_small.csv"

out_l=$(fenrir-tmp)
out_u=$(fenrir-tmp)

in_matrix=$(fenrir-tmp)
cp "$src" "$in_matrix"

if ! lokiw "$destination/bash/lu/decomposition.sh" "$in_matrix" "$out_l" "$out_u" "2"; then
    loki-log fail "SM: Script execution has failed"
    exit 1
fi

if ! diff --minimal "$in_matrix" "$src"; then
    loki-log err "SM: You have modified source matrix"
    exit 4
fi

if ! diff --minimal "$out_l" "$l"; then
    loki-log err "SM: Wrong L matrix"
    exit 3
fi

if ! diff --minimal "$out_u" "$u"; then
    loki-log err "SM: Wrong U matrix"
    exit 2
fi

loki-log succ "SM: PASSED"
