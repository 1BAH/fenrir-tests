#! /usr/bin/env loki

destination=$(fenrir-read-conf main root)

loki-log info "LM: Running on large matrix (7x7).."

# Setup logs
src="/etc/fenrir/in_large.csv"
l="/etc/fenrir/l_large.csv"
u="/etc/fenrir/u_large.csv"

out="/var/fenrir/out"
err="/var/fenrir/err"

out_l=$(fenrir-tmp)
out_u=$(fenrir-tmp)

in_matrix=$(fenrir-tmp)
cp "$src" "$in_matrix"

if ! lokiw "$destination/bash/lu/decomposition.sh" "$in_matrix" "$out_l" "$out_u" "3"; then
    loki-log fail "LM: Script execution has failed"
    exit 1
fi

if ! diff --minimal "$in_matrix" "$src"; then
    loki-log err "LM: You have modified source matrix"
    exit 4
fi

if ! diff --minimal "$out_l" "$l"; then
    loki-log err "LM: Wrong L matrix"
    exit 3
fi

if ! diff --minimal "$out_u" "$u"; then
    loki-log err "LM: Wrong U matrix"
    exit 2
fi

loki-log succ "LM: PASSED"
