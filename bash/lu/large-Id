#! /usr/bin/env loki


destination=$(fenrir-read-conf main root)

# Setup logs
src=$(fenrir-tmp)
l=$(fenrir-tmp)
u=$(fenrir-tmp)

dim=25

loki-log info "LID: Testing identity matrix with dim='$dim'"

{
    for (( i = 0; i < dim - 1; ++i )); do
        for (( j = 0; j < dim - 1; ++j )); do
            if [ "$i" -ne "$j" ]; then
                echo -n "0,"
            else
                echo -n "1,"
            fi
        done

        echo "0"
    done

    for (( i = 0; i < dim - 1; ++i )); do
        echo -n "0,"
    done

    echo "1"
} >> "$src"

in_matrix=$(fenrir-tmp)
cp "$src" "$in_matrix"

if ! lokiw "$destination/bash/lu/decomposition.sh" "$in_matrix" "$l" "$u" "0"; then
    loki-log fail "LID: Script execution has failed"
    exit 1
fi

if ! diff --minimal "$in_matrix" "$src"; then
    loki-log err "LID: You have modified source matrix"
    exit 4
fi

if ! diff --minimal "$l" "$src"; then
    loki-log err "LID: Wrong L matrix"
    exit 3
fi

if ! diff --minimal "$u" "$src"; then
    loki-log err "LID: Wrong U matrix"
    exit 2
fi

loki-log succ "LID: PASSED"

# Successfully passed all tests
loki-points +100

