#! /usr/bin/env loki

destination=$(fenrir-read-conf main root)

loki-log info "BM: Running on broken csv (no LF).."

# Setup logs
src="$(fenrir-task-path cfgs)/in_broken.csv"
l="$(fenrir-task-path cfgs)/l_broken.csv"
u="$(fenrir-task-path cfgs)/u_broken.csv"

out_l=$(fenrir-tmp)
out_u=$(fenrir-tmp)

in_matrix=$(fenrir-tmp)
cp "$src" "$in_matrix"

echo "Бугагашеньки" > "$out_u"
echo "Buzzinga"     > "$out_l"

if ! lokiw "$destination/bash/lu/decomposition.sh" "$in_matrix" "$out_l" "$out_u" "1"; then
    loki-log fail "BM: Script execution has failed"
    exit 1
fi

if ! diff --minimal "$in_matrix" "$src"; then
    loki-log err "BM: You have modified source matrix"
    exit 4
fi

if ! diff --minimal "$out_l" "$l"; then
    loki-log err "BM: Wrong L matrix"
    exit 3
fi

if ! diff --minimal "$out_u" "$u"; then
    loki-log err "BM: Wrong U matrix"
    exit 2
fi

loki-log succ "BM: PASSED"
