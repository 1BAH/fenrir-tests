#! /usr/bin/env loki


loki-set-log-prefix "TR: "
loki-log info "Running on tricky logs.."

# Setup logs
dir=$(fenrir-tmp -d)

lokiw -e pushd "$dir"
{
  echo "[ ERROR ] 11:12:2024 07 PANIC"
  echo "[ DEBUG ] 12:12:2024 2 БУГАГАШЕНЬКИ"
  echo "[ INFО ] 12:12:2024 4 RELOAD"
  echo "[ WARNING ] 13:12:2024 1000000000001 FAILURE"
} > log.log
lokiw -e popd

# Running up
lokiw -e "./bash/logs/parse-logs.sh" -o up -l 3 "$dir"

content=$(loki-get-out)

if [ "$(echo "$content" | wc -l)" -ne 1 ]; then
    loki-log fail "Expected 1 line but got '$(echo "$content" | wc -l)'"
    exit 9
fi

loki-assert-eq "[ WARNING ] 13:12:2024 1000000000001 FAILURE" "$(echo "$content" | sed '1p;d')"


# Running down
lokiw -e "./bash/logs/parse-logs.sh" --lines 33 --order down "$dir"

content=$(cat "$out")

if [ "$(echo "$content" | wc -l)" -ne 1 ]; then
    loki-log fail "Expected 1 line but got '$(echo "$content" | wc -l)'"
    exit 9
fi

loki-assert-eq "[ WARNING ] 13:12:2024 1000000000001 FAILURE" "$(echo "$content" | sed '1p;d')"

loki-points +30
