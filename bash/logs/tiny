#! /usr/bin/env loki

loki-set-log-prefix "TN: "
loki-log info "Running on tiny logs.."
destination=$(fenrir-read-conf run root)

# Setup logs
dir=$(fenrir-tmp -d)

lokiw -e pushd "$dir"
{
    echo "[ ERROR ] 11:12:2024 7 PANIC"
    echo "[ DEBUG ] 12:12:2024 2 START"
    echo "[ INFO ] 12:12:2024 4 RELOAD"
    echo "[ WARNING ] 13:12:2024 10 FAILURE"
} > log.log
lokiw -e popd

# Running up
lokiw -e "$destination/bash/logs/parse-logs.sh" "-l" "2" "$dir"

content=$(loki-get-out)

if [ "$(echo "$content" | wc -l)" -ne 2 ]; then
    loki-log fail "Expected 2 lines but got '$(echo "$content" | wc -l)'"
    exit 9
fi

loki-assert-eq "[ WARNING ] 13:12:2024 10 FAILURE" "$(echo "$content" | sed '1p;d')"
loki-assert-eq "[ ERROR ] 11:12:2024 7 PANIC"      "$(echo "$content" | sed '2p;d')"


# Running down
lokiw -e "$destination/bash/logs/parse-logs.sh" "--lines" "2" "-o" "down" "$dir"

content=$(loki-get-out)

if [ "$(echo "$content" | wc -l)" -ne 2 ]; then
    loki-log fail "Expected 2 lines but got '$(echo "$content" | wc -l)'"
    exit 9
fi

loki-assert-eq "[ INFO ] 12:12:2024 4 RELOAD" "$(echo "$content" | sed '1p;d')"
loki-assert-eq "[ DEBUG ] 12:12:2024 2 START" "$(echo "$content" | sed '2p;d')"

loki-points +20
