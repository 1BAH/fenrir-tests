#! /bin/bash

# repo=$1
verbosity=$2
destination=$(getroot)
out="/var/fenrir/out"
err="/var/fenrir/err"

log info "$verbosity" "TN: Running on tiny logs.."

# Setup logs
dir=$(mktemp -d)

pushd "$dir" &> /dev/null
{
    echo "[ ERROR ] 11:12:2024 7 PANIC"
    echo "[ DEBUG ] 12:12:2024 2 START"
    echo "[ INFO ] 12:12:2024 4 RELOAD"
    echo "[ WARNING ] 13:12:2024 10 FAILURE"
} > log.log
popd &> /dev/null

# Running up
if ! "$destination/bash/logs/parse-logs.sh" "-l" "2" "$dir" > "$out" 2> "$err"; then
    log err "$verbosity" "TN: Script execution has failed"
    log warn "$verbosity" "<stdout>" "$(cat "$out")"
    log err "$verbosity" "<stderr>" "$(cat "$err")"
    exit 1
fi

content=$(cat "$out")

if [ "$(echo "$content" | wc -l)" -ne 2 ]; then
    log err "$verbosity" "TN: Expected 2 lines but got '$(echo "$content" | wc -l)'"
    exit 9
fi

if ! [ "$(echo "$content" | sed '1p;d')" = "[ WARNING ] 13:12:2024 10 FAILURE" ]; then
        log err "$verbosity" "TN: Wrong output:"
        log err "$verbosity" "    Expected <[ WARNING ] 13:12:2024 10 FAILURE>"
        log err "$verbosity" "    Got <$(echo "$content" | sed '1p;d')>"
        exit 1
fi

if ! [ "$(echo "$content" | sed '2p;d')" = "[ ERROR ] 11:12:2024 7 PANIC" ]; then
        log err "$verbosity" "TN: Wrong output:"
        log err "$verbosity" "    Expected <[ ERROR ] 11:12:2024 7 PANIC>"
        log err "$verbosity" "    Got <$(echo "$content" | sed '2p;d')>"
        exit 1
fi


# Running down
if ! "$destination/bash/logs/parse-logs.sh" "--lines" "2" "-o" "down" "$dir" > "$out" 2> "$err"; then
    log err "$verbosity" "TN: Script execution has failed"
    log warn "$verbosity" "<stdout>" "$(cat "$out")"
    log err "$verbosity" "<stderr>" "$(cat "$err")"
    exit 1
fi

content=$(cat "$out")

if [ "$(echo "$content" | wc -l)" -ne 2 ]; then
    log err "$verbosity" "TN: Expected 2 lines but got '$(echo "$content" | wc -l)'"
    exit 9
fi

if ! [ "$(echo "$content" | sed '1p;d')" = "[ INFO ] 12:12:2024 4 RELOAD" ]; then
        log err "$verbosity" "TN: Wrong output!"
        log err "$verbosity" "    Expected <[ INFO ] 12:12:2024 4 RELOAD>"
        log err "$verbosity" "    Got <$(echo "$content" | sed '1p;d')>"
        exit 1
fi

if ! [ "$(echo "$content" | sed '2p;d')" = "[ DEBUG ] 12:12:2024 2 START" ]; then
        log err "$verbosity" "TN: Wrong output!"
        log err "$verbosity" "    Expected <[ DEBUG ] 12:12:2024 2 START>"
        log err "$verbosity" "    Got <$(echo "$content" | sed '2p;d')>"
        exit 1
fi

add-points 20

log succ "$verbosity" "TN: PASSED"
